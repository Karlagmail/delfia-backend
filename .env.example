# ============================================================
# DELFIAAPP SaaS — Variáveis de Ambiente
# Copie para .env e preencha. NUNCA suba o .env para o GitHub!
# ============================================================

# Banco de dados (Railway gera automaticamente)
DATABASE_URL=postgresql://usuario:senha@host:5432/delfiaapp

# JWT
JWT_SECRET=gere_uma_string_longa_e_aleatoria_aqui_minimo_32_chars

# Servidor
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://app.delfiaapp.com.br

# ============================================================
# STRIPE — Pagamentos
# Crie em: https://dashboard.stripe.com/apikeys
# ============================================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_PRICE_LOJA_EXTRA=price_...

# ============================================================
# HOSTINGER API — DNS e E-mails
# Crie em: https://developers.hostinger.com
# ============================================================
HOSTINGER_API_KEY=seu_token_hostinger_aqui
HOSTINGER_API_URL=https://api.hostinger.com/v1

# ============================================================
# SUPERADMIN INICIAL
# ============================================================
SUPERADMIN_EMAIL=superadmin@delfiaapp.com.br
SUPERADMIN_SENHA=troque_esta_senha_urgente
SUPERADMIN_NOME=Super Admin

# ============================================================
# EMPRESA DELFIA FOODS (primeiro tenant)
# ============================================================
DELFIA_ADMIN_EMAIL=admin@delfiafoods.com.br
DELFIA_ADMIN_SENHA=delfia2024
DELFIA_ADMIN_NOME=Administrador Delfia
